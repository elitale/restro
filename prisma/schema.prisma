// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum GstRegistrationType {
  REGULAR
  COMPOSITION
  UNREGISTERED
}

enum MenuItemType {
  SERVED
  PACKAGED_GOODS
}

enum DietaryType {
  VEG
  NON_VEG
  EGG
}

enum Disable86Reason {
  OUT_OF_STOCK
  QUALITY
  PREP_TIME
  OTHER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  OPEN
  COMPLETED
  VOID
}

enum OrderLineState {
  UNSENT
  FIRED
  SERVED
  VOID
}

enum PaymentMode {
  CASH
  UPI
  CARD
  OTHER
}

enum DiscountType {
  NONE
  PERCENT
  FLAT
}

/// Restaurant manager / operator account.
/// Phone number is the primary identifier used to sign in; email is optional
/// and can be added later for notifications (Resend).
model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  phoneVerifiedAt DateTime?
  email           String?   @unique
  emailVerifiedAt DateTime?
  name            String?
  role            UserRole  @default(MANAGER)
  isActive        Boolean   @default(true)
  suspendedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownedRestaurants Restaurant[] @relation("RestaurantOwner")

  @@index([role])
}

/// A restaurant onboarded onto the platform, owned by a manager (User).
model Restaurant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  email       String?
  phone       String?
  city        String?
  country     String    @default("IN")
  timezone    String?

  // GST / tax profile (opt-in; drives the correct default tax at billing time)
  gstRegistrationType GstRegistrationType @default(UNREGISTERED)
  serviceGstRate      Decimal?            @db.Decimal(5, 2)
  pricesTaxInclusive  Boolean             @default(false)
  gstin               String?
  sacCode             String?             @default("996331")
  nextInvoiceSeq      Int                 @default(1)

  isActive    Boolean   @default(true)
  onboardedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  ownerId String
  owner   User   @relation("RestaurantOwner", fields: [ownerId], references: [id])

  categories     MenuCategory[]
  menuItems      MenuItem[]
  modifierGroups ModifierGroup[]
  orders         Order[]

  @@index([ownerId])
  @@index([isActive])
}

/// One-time passcode challenge for phone (SMS) login. Codes are stored hashed.
model OtpChallenge {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone])
}

/// A menu section (Starters, Mains, Beverages…). Owned by a Restaurant.
model MenuCategory {
  id           String    @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  items      MenuItem[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

/// A sellable menu item. `price` is the base/default; variants (if any) are the
/// sellable units. Tax is resolved from the Restaurant profile unless the item
/// is PACKAGED_GOODS with its own goodsGstRate.
model MenuItem {
  id                String       @id @default(cuid())
  restaurantId      String
  categoryId        String
  name              String
  shortDescription  String?
  longDescription   String?
  itemType          MenuItemType @default(SERVED)
  dietaryType       DietaryType?
  price             Decimal      @db.Decimal(10, 2)
  priceTaxInclusive Boolean?
  goodsGstRate      Decimal?     @db.Decimal(5, 2)
  hsnSacCode        String?
  sortOrder         Int          @default(0)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  restaurant     Restaurant              @relation(fields: [restaurantId], references: [id])
  category       MenuCategory            @relation(fields: [categoryId], references: [id])
  images         MenuItemImage[]
  disables       MenuItemAvailability[]
  variants       MenuItemVariant[]
  modifierGroups MenuItemModifierGroup[]

  @@index([restaurantId])
  @@index([categoryId])
}

/// Uploaded photo for a menu item (stored in Supabase Storage).
model MenuItemImage {
  id         String   @id @default(cuid())
  menuItemId String
  url        String
  storageKey String
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

/// A time-boxed "86" (disable) event for an item; also the availability audit log.
model MenuItemAvailability {
  id            String          @id @default(cuid())
  menuItemId    String
  reason        Disable86Reason
  note          String?
  disabledById  String
  disabledAt    DateTime        @default(now())
  resumeAt      DateTime?
  reenabledAt   DateTime?
  reenabledById String?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

/// A size/portion variant of an item (Half/Full, S/M/L) with its own price.
model MenuItemVariant {
  id         String    @id @default(cuid())
  menuItemId String
  name       String
  price      Decimal   @db.Decimal(10, 2)
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

/// A reusable group of add-ons ("Milk", "Add-ons") attachable to many items.
model ModifierGroup {
  id           String    @id @default(cuid())
  restaurantId String
  name         String
  minSelect    Int       @default(0)
  maxSelect    Int       @default(1)
  isRequired   Boolean   @default(false)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  restaurant Restaurant              @relation(fields: [restaurantId], references: [id])
  modifiers  Modifier[]
  items      MenuItemModifierGroup[]

  @@index([restaurantId])
}

/// A single add-on option within a ModifierGroup, with a price delta.
model Modifier {
  id         String   @id @default(cuid())
  groupId    String
  name       String
  priceDelta Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

/// Join: which modifier groups apply to which items (groups are reusable).
model MenuItemModifierGroup {
  menuItemId      String
  modifierGroupId String
  sortOrder       Int    @default(0)

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, modifierGroupId])
  @@index([modifierGroupId])
}

/// A customer order (takeaway / dine-in tab / manual delivery). Stays OPEN and
/// mutable until settled; lines snapshot price + tax so old bills never change.
model Order {
  id              String       @id @default(cuid())
  restaurantId    String
  orderNumber     Int
  invoiceNumber   Int?
  idempotencyKey  String       @unique
  orderType       OrderType    @default(TAKEAWAY)
  status          OrderStatus  @default(OPEN)
  tableLabel      String?
  customerName    String?
  customerPhone   String?
  customerAddress String?
  note            String?

  subtotal       Decimal      @default(0) @db.Decimal(10, 2)
  taxTotal       Decimal      @default(0) @db.Decimal(10, 2)
  discountType   DiscountType @default(NONE)
  discountValue  Decimal      @default(0) @db.Decimal(10, 2)
  discountReason String?
  discountTotal  Decimal      @default(0) @db.Decimal(10, 2)
  compTotal      Decimal      @default(0) @db.Decimal(10, 2)
  roundOff       Decimal      @default(0) @db.Decimal(10, 2)
  grandTotal     Decimal      @default(0) @db.Decimal(10, 2)

  placedById String
  voidedById String?
  voidReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  settledAt  DateTime?
  deletedAt  DateTime?

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
  payments   Payment[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status])
}

/// One line on an order — fully snapshotted from the menu at add time.
model OrderItem {
  id           String         @id @default(cuid())
  orderId      String
  menuItemId   String?
  variantId    String?
  name         String
  variantName  String?
  unitPrice    Decimal        @db.Decimal(10, 2)
  quantity     Int            @default(1)
  lineNote     String?
  taxRate      Decimal        @default(0) @db.Decimal(5, 2)
  taxKind      String         @default("NONE")
  taxInclusive Boolean        @default(false)
  state        OrderLineState @default(UNSENT)
  isComp       Boolean        @default(false)
  compReason   String?
  firedAt      DateTime?
  voidReason   String?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiers OrderItemModifier[]

  @@index([orderId])
}

/// A chosen add-on on an order line — snapshotted.
model OrderItemModifier {
  id          String  @id @default(cuid())
  orderItemId String
  modifierId  String?
  name        String
  priceDelta  Decimal @default(0) @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

/// A tender against an order (multi-tender supported).
model Payment {
  id           String      @id @default(cuid())
  orderId      String
  mode         PaymentMode
  amount       Decimal     @db.Decimal(10, 2)
  tendered     Decimal?    @db.Decimal(10, 2)
  reference    String?
  receivedById String
  createdAt    DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
