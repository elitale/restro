# --- Database (Prisma / PostgreSQL) ---
# Any Postgres connection string. Prisma 7 uses the pg driver adapter.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth / sessions ---
# Secret used to sign session JWTs (jose) and hash OTP/PIN codes. Use a long random string.
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# In dev only: makes getCurrentUserId() return this user id without a session.
# Leave empty in production.
DEV_ADMIN_USER_ID=""

# --- SMS OTP (Twilio Programmable Messaging) ---
TWILLIO_A_SID=""
TWILLIO_AUTH_SECRET=""
TWILLIO_PRIMARY_TOKEN=""
TWILLIO_FROM_NUMBER="+10000000000"

# --- Email (Resend) — optional, for notifications ---
AUTH_RESEND_KEY=""
RESEND_FROM_EMAIL="ElitaleRestro <no-reply@example.com>"

# --- Image/video storage (Supabase Storage, S3-compatible) ---
SUPABASE_S3_ENDPOINT="https://<project>.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="ap-south-1"
SUPABASE_S3_BUCKET_NAME="your-bucket"
SUPABASE_S3_ACCESS_KEY=""
SUPABASE_S3_SECRET_KEY=""

# --- Cron / scheduled tasks (optional) ---
CRON_SECRET=""
